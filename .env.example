# --- Django core ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,host.docker.internal
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# --- Database ---
# Railway Postgres plugin provides DATABASE_URL automatically.
# DATABASE_URL=postgres://user:pass@host:5432/railway
POSTGRES_DB=mastergo
POSTGRES_USER=mastergo
POSTGRES_PASSWORD=mastergo
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis (Channels + OTP cache) ---
# Railway Redis plugin provides REDIS_URL automatically.
REDIS_URL=redis://localhost:6379/0

# Quick local smoke runs without Postgres/Redis:
MASTERGO_USE_SQLITE=0
MASTERGO_SQLITE_PATH=.tmp/backend_dev.sqlite3
MASTERGO_USE_INMEMORY_CHANNELS=0

# --- SMS OTP (Eskiz.uz) ---
# MASTERGO_MOCK_OTP=1  -> fixed code, no SMS (login with the code below).
# For real SMS: MASTERGO_MOCK_OTP=0, SMS_DRY_RUN=0, fill Eskiz creds.
MASTERGO_MOCK_OTP=1
MASTERGO_MOCK_OTP_CODE=1111
SMS_DRY_RUN=1
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_BASE_URL=https://notify.eskiz.uz/api
ESKIZ_SENDER=4546
OTP_SMS_TEMPLATE=Opus: tasdiqlash kodi {code}. Hech kimga bermang.

# --- Maps ---
MASTERGO_2GIS_KEY=502c1521-9ee2-4de8-bec6-15b5f882c08e